import pandas as pd
import undetected_chromedriver as uc

from bs4 import BeautifulSoup
import time
import undetected_chromedriver as uc

options = uc.ChromeOptions()
options.add_argument('--no-sandbox')
options.add_argument('--disable-dev-shm-usage')

# Create the driver with options and version specification
driver = uc.Chrome(
    options=options,
    use_subprocess=True,
    version_main=141  # Set to match your Chrome version (141.0.7390.123)
)

# Add a small delay to ensure browser initializes properly
time.sleep(2)
driver.get('https://fbref.com/en/comps/22/stats/Major-League-Soccer-Stats')
df = pd.read_html(driver.page_source, attrs={'id': "stats_standard"})[0]
df.columns = ['_'.join(col).strip() for col in df.columns.values]
file_path = "/Users/xxxxxx/Documents/Spreadsheets/mls_stats.xlsx"
df.to_excel(file_path, index=False)
print(f"Data saved to {file_path}")
